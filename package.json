    "preview": "vite preview",
    "typecheck": "node ./node_modules/typescript-7/bin/tsc --noEmit",
    "lint": "eslint . --cache --cache-location .eslintcache --cache-strategy content",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,css,md}\" \"functions/**/*.js\" \"*.{html,json,js,cjs,md}\" \"public/**/*.{html,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,css,md}\" \"functions/**/*.js\" \"*.{html,json,js,cjs,md}\" \"public/**/*.{html,json}\"",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck && react-doctor --verbose"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.4",
    "dompurify": "^3.4.12",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.25.0",
    "postcss": "^8.5.20",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.3",
    "vite": "^8.1.5",
    "vite-plugin-svgr": "^5.2.0"
  },
  "browserslist": {
